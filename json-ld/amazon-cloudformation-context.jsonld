          "@id": "schema:description",
          "@type": "xsd:string"
        },
        "ExportName": {
          "@id": "cfn:ExportName",
          "@type": "xsd:string"
        }
      }
    },
    "Tag": {
      "@id": "cfn:Tag",
      "@context": {
        "Key": {
